rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    // 2. MoodHistory Validation Blueprint
    function isValidMoodHistory(data) {
      return data.keys().hasAll(['userId', 'mood', 'timestamp']) &&
             data.keys().size() <= 4 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.mood is string && data.mood.size() <= 100 &&
             data.timestamp is timestamp;
    }

    // 3. ChatSession Validation Blueprint
    function isValidChatSession(data) {
      return data.keys().hasAll(['userId', 'preview', 'timestamp']) &&
             data.keys().size() <= 4 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.preview is string && data.preview.size() <= 500 &&
             data.timestamp is timestamp;
    }

    // --- Collection Routes ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin', 'displayName', 'photoURL', 'motivation', 'email']) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;

      // Subcollection: Mood History
      match /mood_history/{moodId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(moodId) && isValidMoodHistory(request.resource.data) && request.resource.data.timestamp == request.time;
        // Mood history is usually immutable, but we'll allow delete
        allow delete: if isOwner(userId);
      }

      // Subcollection: Chat Sessions
      match /chat_sessions/{sessionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatSession(request.resource.data) && request.resource.data.timestamp == request.time;
        allow delete: if isOwner(userId);
      }
    }
  }
}
