{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information stored upon first login",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "motivation": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "MoodHistory": {
      "title": "Mood Entry",
      "description": "Historical record of user moods",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "stickerUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "ChatSession": {
      "title": "Chat Story",
      "description": "A saved chat session or story summary",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "preview": { "type": "string" },
        "mood": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "preview", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/users/{userId}/mood_history/{moodId}": {
      "schema": "MoodHistory",
      "description": "Subcollection for user mood history"
    },
    "/users/{userId}/chat_sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Subcollection for saved chat stories"
    }
  }
}
